# ============================================================
# VARIABLES DE ENTORNO REQUERIDAS EN PRODUCCION
# Copia este archivo a .env (NO lo subas a git) y rellena
# cada valor. En tu servidor, exporta estas variables o usa
# el sistema de secrets de tu plataforma (Railway, Render,
# Fly.io, Docker secrets, Kubernetes secrets, etc.).
# ============================================================

# ------------------------------------------------------------
# SERVIDOR
# ------------------------------------------------------------
PORT=8080
# Puerto separado para el endpoint de health check de Actuator
MANAGEMENT_PORT=8081

# Perfil activo de Spring Boot — SIEMPRE "prod" en produccion
SPRING_PROFILES_ACTIVE=prod

# Dominio del servidor (sin https:// ni barra final)
# Ejemplo: impofer.com  o  www.impofer.com
NGINX_SERVER_NAME=ferreteriaimpofer.com

# ------------------------------------------------------------
# BASE DE DATOS PostgreSQL
# ------------------------------------------------------------
DB_URL=jdbc:postgresql://<host>:5432/<database>
DB_USERNAME=<usuario_db>
DB_PASSWORD=<contrasena_db_muy_segura>

# ------------------------------------------------------------
# JWT
# Genera una clave aleatoria de al menos 64 caracteres:
#   openssl rand -base64 64
# ------------------------------------------------------------
JWT_SECRET=<clave_aleatoria_minimo_64_chars>
# Duracion del token en milisegundos (14400000 = 4 horas en prod)
JWT_EXPIRATION=14400000

# ------------------------------------------------------------
# STRIPE
# Usa llaves de produccion reales cargadas desde tu gestor de secretos.
# ------------------------------------------------------------
STRIPE_API_KEY=<stripe_secret_key>
STRIPE_WEBHOOK_SECRET=<stripe_webhook_secret>

# ------------------------------------------------------------
# CORREO ELECTRONICO (SMTP)
# ------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=impofersl@gmail.com
MAIL_PASSWORD=<app_password_de_gmail>

# ------------------------------------------------------------
# CORS
# Dominio(s) de tu frontend separados por coma.
# NO incluyas barra final. Ejemplo:
#   https://impofer.com,https://www.impofer.com
# ------------------------------------------------------------
ALLOWED_ORIGINS=https://impofer.com,https://www.impofer.com

# URL base de la aplicacion (usada en emails de recuperacion de contrasena)
APP_BASE_URL=https://impofer.com

# ------------------------------------------------------------
# SSL (opcional — si Spring Boot maneja TLS directamente)
# Si usas un reverse proxy (nginx, Caddy, Traefik) que
# termina TLS, deja estos comentados.
# ------------------------------------------------------------
# SSL_KEYSTORE_PATH=/ruta/al/keystore.p12
# SSL_KEYSTORE_PASSWORD=<contrasena_keystore>
